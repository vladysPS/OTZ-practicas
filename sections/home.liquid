    <div class="absolute bottom-[35px] right-[18px] w-[45px] h-[45px] bg-white rounded-[23px] flex items-center justify-center shadow-lg">
      <div class="w-[25px] h-[25px]">
        <img src="https://assets.shopdev.ai/figma-imports/41919242-e66a-4323-8750-9f57d873b085/2edaad96790f4b665e558de147462e0230cf28d2.svg" />
      </div>
    </div>
  </div>

  <!-- Product Section -->
  <div class="w-full py-[79px] px-[20px]">
    <!-- Title -->
    <div class="mb-[55px]">
      <div class="text-center mb-[10px]">
        <p class="text-black text-[12px] font-light uppercase tracking-wide">
          {{ section.settings.tagline }}
        </p>
      </div>
      <div class="text-center">
        <h2 class="text-black text-[40px] font-extralight leading-[100%]">
          {{ section.settings.heading }}
        </h2>
      </div>
    </div>

    <!-- Product Images -->
    <div class="relative w-full h-[484px]">
      <!-- Blur Background Images -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="flex gap-0 h-[346px] mt-[10px]">
          <div class="w-[281px] h-[346px] opacity-30 blur-sm">
            {%- if section.settings.product_image_left != blank -%}
              {{ section.settings.product_image_left | image_url: width: 600 | image_tag: 
                loading: 'lazy',
                class: 'w-full h-full object-cover',
                sizes: '300px'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
            {%- endif -%}
          </div>
          <div class="w-[281px] h-[346px] opacity-30 blur-sm ml-[-147px]">
            {%- if section.settings.product_image_right != blank -%}
              {{ section.settings.product_image_right | image_url: width: 600 | image_tag: 
                loading: 'lazy',
                class: 'w-full h-full object-cover',
                sizes: '300px'
              }}
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Main Product Content -->
      <div class="relative mx-auto max-w-[301px] pt-[10px] pb-[10px] px-[10px]">
        <div class="w-full">
          <!-- Product Image -->
          <div class="w-full h-[346px] mb-[18px]">
            {%- if section.settings.featured_product_image != blank -%}
              {{ section.settings.featured_product_image | image_url: width: 600 | image_tag: 
                loading: 'lazy',
                class: 'w-full h-full object-cover',
                sizes: '300px'
              }}
            {%- else -%}
              {{ 'product-3' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
            {%- endif -%}
          </div>

          <!-- Product Details -->
          <div class="text-center mb-[18px]">
            <h3 class="text-black text-[24px] font-extralight leading-[100%] mb-[8px]">
              {{ section.settings.product_name }}
            </h3>
            <p class="text-black text-[10px] font-normal leading-[150%]">
              {{ section.settings.product_price }}
            </p>
          </div>

          <!-- Button -->
          <div class="w-full">
            {% if section.settings.button_link != blank %}
              <a href="{{ section.settings.button_link }}" 
                 class="block w-full h-[35px] bg-white border border-black flex items-center justify-center text-black text-[12px] font-light uppercase tracking-wide transition-all duration-300 hover:bg-black hover:text-white">
                {{ section.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Intro Homepage -->
  <div class="w-full py-[120px] px-[43px] bg-white">
    <div class="text-center mb-[45px]">
      <h2 class="text-black text-[40px] font-extralight leading-[100%] mb-[45px]">
        {{ section.settings.intro_text | newline_to_br }}
      </h2>
      
      {% if section.settings.intro_button_link != blank %}
        <a href="{{ section.settings.intro_button_link }}" 
           class="inline-block w-full max-w-[280px] h-[35px] bg-white border border-black flex items-center justify-center text-black text-[12px] font-light uppercase tracking-wide transition-all duration-300 hover:bg-black hover:text-white mx-auto">
          {{ section.settings.intro_button_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Essence Module -->
  <div class="w-full h-[550px] bg-white px-[33px] py-[45px]">
    {%- if section.settings.essence_image != blank -%}
      {{ section.settings.essence_image | image_url: width: 800 | image_tag: 
        loading: 'lazy',
        class: 'w-full h-full object-cover',
        sizes: '100vw'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
    {%- endif -%}
  </div>

  <!-- Product Dark Section -->
  <div class="w-full bg-black py-[64px] px-[17px]">
    <div class="text-center mb-[58px]">
      <h2 class="text-white text-[60px] font-extralight leading-[100%] mb-[58px]">
        {{ section.settings.essence_heading | newline_to_br }}
      </h2>
      
      <div class="w-full max-w-[308px] h-[179px] mx-auto mb-[57px]">
        {%- if section.settings.essence_product_image != blank -%}
          {{ section.settings.essence_product_image | image_url: width: 400 | image_tag: 
            loading: 'lazy',
            class: 'w-full h-full object-contain',
            sizes: '300px'
          }}
        {%- else -%}
          {{ 'product-4' | placeholder_svg_tag: 'w-full h-full bg-gray-700' }}
        {%- endif -%}
      </div>

      {% if section.settings.essence_button_link != blank %}
        <a href="{{ section.settings.essence_button_link }}" 
           class="inline-block w-full max-w-[280px] h-[35px] bg-black border border-white flex items-center justify-center text-white text-[12px] font-light uppercase tracking-wide transition-all duration-300 hover:bg-white hover:text-black mx-auto">
          {{ section.settings.essence_button_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Film Module -->
  <div class="w-full h-[550px] bg-gray-900 relative">
    {%- if section.settings.film_video != blank -%}
      {{ section.settings.film_video | video_tag: 
        autoplay: true,
        loop: true,
        muted: true,
        class: 'w-full h-full object-cover'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full bg-gray-800' }}
    {%- endif -%}
    
    <!-- Film Controls -->
    <div class="absolute bottom-[32px] right-[18px] flex gap-[10px]">
      <div class="w-[44px] h-[34px] bg-white flex items-center justify-center">
        <div class="w-[15px] h-[15px]">
          <img src="https://assets.shopdev.ai/figma-imports/41919242-e66a-4323-8750-9f57d873b085/a075d3f598a039c57bc0da794431fd0904d64e56.svg" />
        </div>
      </div>
      <div class="w-[44px] h-[34px] bg-white flex items-center justify-center">
        <div class="w-[15px] h-[15px]">
          <img src="https://assets.shopdev.ai/figma-imports/41919242-e66a-4323-8750-9f57d873b085/c73a57a3ed6e4a16edb28c64ec3ee7e0c13a15c3.svg" />
        </div>
      </div>
    </div>
  </div>

  <!-- Intensity Range -->
  <div class="w-full bg-white py-[50px]">
    <div class="px-[18px]">
      <!-- Intensity Details -->
      <div class="text-center mb-[40px]">
        <h2 class="text-black text-[40px] font-extralight leading-[100%] mb-[20px]">
          {{ section.settings.spectrum_heading | newline_to_br }}
        </h2>
        <p class="text-black text-[12px] font-light uppercase tracking-wide leading-[120%]">
          {{ section.settings.spectrum_description }}
        </p>
      </div>

      <!-- Intensity Levels -->
      <div class="flex items-center justify-center gap-[16px] mb-[40px]">
        <span class="text-black text-[10px] font-light uppercase">1</span>
        <span class="text-black text-[10px] font-light uppercase">2 LUMIÈRES</span>
        <span class="text-black text-[10px] font-light uppercase">3</span>
        <span class="text-black text-[10px] font-light uppercase">4</span>
        <span class="text-black text-[10px] font-light uppercase">5</span>
        <span class="text-black text-[10px] font-light uppercase">6</span>
        <span class="text-black text-[10px] font-light uppercase">7</span>
        <span class="text-black text-[10px] font-light uppercase">8</span>
      </div>

      <!-- Soundscape Cards -->
      <div class="flex flex-col gap-[2px] overflow-x-auto mb-[50px]">
        <div class="flex gap-[2px] min-w-max">
          {% for block in section.blocks %}
            <div class="relative" style="width: {{ block.settings.card_width }}px; height: {{ block.settings.card_height }}px;" {{ block.shopify_attributes }}>
              {%- if block.settings.card_image != blank -%}
                {{ block.settings.card_image | image_url: width: 400 | image_tag: 
                  loading: 'lazy',
                  class: 'w-full h-full object-cover',
                  sizes: '300px'
                }}
              {%- else -%}
                {%- assign placeholder_index = forloop.index | modulo: 6 -%}
                {%- if placeholder_index == 0 -%}
                  {%- assign placeholder_index = 6 -%}
                {%- endif -%}
                {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'w-full h-full bg-gray-300' }}
              {%- endif -%}
              
              <div class="absolute top-[14px] left-[11px]">
                <p class="text-white text-[10px] font-light uppercase leading-[120%]">
                  {{ block.settings.card_label | newline_to_br }}
                </p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- Button -->
      {% if section.settings.spectrum_button_link != blank %}
        <div class="text-center">
          <a href="{{ section.settings.spectrum_button_link }}" 
             class="inline-block w-full max-w-[280px] h-[35px] bg-white border border-black flex items-center justify-center text-black text-[12px] font-light uppercase tracking-wide transition-all duration-300 hover:bg-black hover:text-white mx-auto">
            {{ section.settings.spectrum_button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>


