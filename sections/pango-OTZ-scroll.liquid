 {
 "name": "Pango Parallax",
 "settings": [
    {
      "type": "text",
      "id": "product_name",
      "label": "Product name"
    },
    {
      "type": "text",
      "id": "product_copy",
      "label": "Product copy"
    },
    {
      "type": "video",
      "id": "video_top",
      "label": "Video top"
    },
    {
      "type": "image_picker",
      "id": "image_top",
      "label": "Image top"
    },
    {
      "type": "video",
      "id": "video_bottom",
      "label": "Video bottom"
    },
    {
      "type": "image_picker",
      "id": "image_bottom",
      "label": "Image bottom"
    }
 ],
 "presets": [
   {
     "name": "Pango Parallax",
     "category": "All Pango"
   }
 ]
} 
{% endschema %}

