<!-- pango-carousel.liquid -->
{%- assign carousel_collection_products = section.settings.carousel_collection.products -%}

<section class="p-{{ section.id }}">
    <div class="p-inner-cont">
        <div class="title-container">
            <span class="alpina-thin">{{ section.settings.text_top }} </span>
            <h2 class="alpina-thin">{{ section.settings.title }} </h2>
        </div>
        <div class="carousel-container">
            <div class="swiper mySwiper-carousel">
                <div class="swiper-wrapper">
                {%- for product in carousel_collection_products -%}
                    <div class="swiper-slide">
                        {{ product.metafields.custom.carousel_image.value |  image_url: width:image.width  |image_tag }}
                        <div class="prod-data" style="display:none;">
                            <h3 class="prod-title">{{ product.title }}</h3>
                            <p class="prod-price">{{ product.price | money }}</p>
                            <a href="{{ product.url }}" class="prod-link"></a>
                        </div>
                    </div>                    
                {%- endfor -%}
                </div>
                <div>
                </div>
                
            </div>
            
        </div>
        <div class="product-info-container">
            <h3 class="product-title alpina-thin">LANCES</h3>
            <p class="product-price">$250</p>
            <div>
                <a href="/" class="main-button-black product-link">shop now</a>
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</section>

<style>
.p-{{ section.id }}{
    .p-inner-cont{
        text-align:center;
        padding: 69px 0;
        .title-container{
            span{
                font-size:12px;
            }
            h2{
                margin: 10px 0 0 0;
                font-size: 40px;
            }
        }
        .carousel-container{
            .swiper {
                width: 100%;
                height: 100%;
                .swiper-slide {
                    text-align: center;
                    font-size: 18px;
                    background: #444;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    height: 300px;
                    
                    img {
                        display: block;
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        filter: blur(3px);
                        transform: scale(1.1);
                    }
                }
                .swiper-slide-active{
                    img {
                        filter: blur(0);
                        transform: scale(1.2);
                        transition: filter 0.5s ease, transform 0.5s ease;
                    }
                }
            }
        }
        .product-info-container{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-top:18px;    
            h3{
                margin: 0;
                font-size: 24px;
            }
            p{
                margin:8px 0 18px 0;
                font-size: 10px;
            }
            .swiper-pagination{
                position:static;
                .swiper-pagination-bullet{
                    margin:30px 0 0 0;
                    border-radius: 0;
                    width: 30px;
                    height: 1px;
                }
                .swiper-pagination-bullet-active{
                    background-color: #000;
                }
            }
        }

    }

    @media (min-width: 1000px){
        .p-inner-cont{
            padding: 60px;
            .title-container{
                margin-bottom: 30px;
                span{
                    font-size: 16px;
                }
                h2{
                    font-size: 56px;
                }
            }
            .carousel-container{
                .swiper {
                    .swiper-slide {

                        height: auto;
                        

                    }
                    .swiper-slide-active{
                        img {
                            filter: blur(0);
                            transform: scale(1.2);
                            transition: filter 0.5s ease, transform 0.5s ease;
                        }
                    }
                }
            }
            .product-info-container{
                .swiper-pagination{
                    .swiper-pagination-bullet{
                        margin:64px 0 0 0;
                        width: 60px;
                    }
                }
                h3{
                    font-size: 32px;
                }
                p{
                    margin:8px 0 18px 0;
                    font-size: 16px;
                }
            }
        }
    }
}
</style>

<script>
    let swiper = new Swiper(".p-{{ section.id }} .mySwiper-carousel", {
    initialSlide: 1,
    slidesPerView: 2,          
    spaceBetween: 68,          
    centeredSlides: true,        
    breakpoints: {
        768: {
            slidesPerView: 3,    
            spaceBetween: 50, 
        } 
    },  
    pagination: {
        el: ".swiper-pagination",
    },
    on:{
        init: function(){
            updateProductInfo(this);
        },
        slideChange: function(){
            updateProductInfo(this);
        }
    }
    });


    function updateProductInfo(swiperInstance) {
    // 1. Get the container safely
    const sectionContainer = document.querySelector(".p-{{ section.id }}");
    if (!sectionContainer) return;

    const infoContainer = sectionContainer.querySelector(".product-info-container");
    if (!infoContainer) return;

    // 2. Get the active slide. 
    // In loop mode, it's safer to use the slide at the current index
    const activeSlide = swiperInstance.slides[swiperInstance.activeIndex];
    if (!activeSlide) return;

    // 3. Find the data inside the slide
    const prodData = activeSlide.querySelector(".prod-data");
    if (!prodData) return;

    // 4. Extract data with fallback values
    const title = prodData.querySelector(".prod-title")?.textContent || "";
    const price = prodData.querySelector(".prod-price")?.textContent || "";
    const link = prodData.querySelector(".prod-link")?.getAttribute("href") || "#";

    // 5. Update the UI safely
    const uiTitle = infoContainer.querySelector(".product-title");
    const uiPrice = infoContainer.querySelector(".product-price");
    const uiLink = infoContainer.querySelector(".product-link");

    if (uiTitle) uiTitle.textContent = title;
    if (uiPrice) uiPrice.textContent = price;
    if (uiLink) uiLink.setAttribute("href", link);
    }
</script>

{% schema %}
  {
  "name": "Pango Carousel",
  "settings": [
    {
      "type": "collection",
      "id": "carousel_collection",
      "label": "Carousel collection"
    },
        {
      "type": "text",
      "id": "text_top",
      "label": "Text top",
      "default": "EXPLORE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "OUR FRAGRANCES"
    }
  ],
  "presets": [
    {
      "name": "Pango Carousel",
      "category": "All Pango"
    }
  ]
}  
{% endschema %}