<!-- pango-footer.liquid -->

<footer class="p-{{ section.id }}">
 <div class="p-footer-container page-width">
{%- for block in section.blocks -%}
  {%- case block.type -%}
  {%- when 'newsletter_text' -%}
      <div class="p-top-cont">
    <h4 class="alpina-thin">
      {{ block.settings.title }} 
    </h4>
      {{ block.settings.description }}
    <div class="p-mail-container">
    {% form 'customer' %}
        <div class="p-email-container">
            <input class="p-email-input" type="email" name="contact[email]" autocomplete="email" placeholder="{{ 'pango.newsletter.label' | t }}" required/>
            
            <button type="submit" class="p-submit-button" name="commit" id="Subscribe" aria-label="Subscribe to our newsletter">
                {{- 'icon-arrow.svg' | inline_asset_content -}}
            </button>
        </div>

        {%- if form.errors -%}
            <small class="newsletter-form__message form__message" id="ContactFooter-error">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
            <div class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</div>
        {%- endif -%}            

    {% endform %}
    </div>
    </div>
  {%- when 'logo' -%}
    <div class="logo-container">
        {%- assign image_picker_0 = block.settings.image_picker_0 -%}
        {{ image_picker_0 | image_url: width: image_picker_0.width | image_tag: class: 'add_your_class_here', loading: 'lazy' }}
    </div>
  {%- when 'footer_menu' -%}
      <div class="p-footer-menu-container">
        <ul class="alpina-typewriter">
            {%- assign in footer_menu = block.settings.footer_menu.links -%}
            {%- for link in footer_menu -%}
              <li>{{ link.title | link_to: link.url }}</li>              
            {%- endfor -%}
        </ul>
      </div>

  {%- endcase -%} 
{%- endfor -%}

  <div class="p-bottom-container" >
    
      <div class="copyright"><span>© OTZLAB.</span> All rights reserved.</div>
      <div class="p-legal-links">
        <ul >    
          {%- assign legal_menu = section.settings.legal_menu.links -%}
          {%- for link in legal_menu -%}
            <li>{{ link.title | link_to: link.url }}</li>
          {%- endfor -%}    
        </ul>
      </div>
      <div class="p-social-links">
        {% if section.settings.instagram %}
          <a href="">{{'IG.svg' | inline_asset_content}}</a>
        {% endif %}
        {% if section.settings.facebook %}
          <a href="">{{'FB.svg' | inline_asset_content}}</a>
        {% endif %}
        {% if section.settings.tiktok %}
          <a href="">{{'Tiktok.svg' | inline_asset_content}}</a>
        {% endif %}
        {% if section.settings.youtube %}
          <a href="">{{'Youtube.svg' | inline_asset_content}}</a>
        {% endif %}
        {% if section.settings.twitter %}
          <a href="">{{'X.svg' | inline_asset_content}}</a>
        {% endif %}
    </div>
  </div>
  
 </div> 
</footer>




{%  # CSS  %}
<style>
.p-{{ section.id }}{
  background:black;
  color:white;


  .p-footer-container{
    text-align:center;
    padding: 4.2rem 1rem 1.87rem;
    .p-top-cont{
      display:flex;
      flex-direction:column;
      align-items:center;
      h4{
        font-size: 1.5rem;
        margin:0;
        width: 182px;

      }
      p{
        font-size: 0.625rem;
        max-width: 14.31rem;
        margin:1.25rem 0;
      }
      .p-email-container{
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        border-bottom:1px solid white;
        min-width: 14rem;
        input,
        button{
          all:unset;
        }

        input{
          text-align: left;
          padding-left: 10px;
          font-size:0.62rem;
        }

      }
    }
    .logo-container{
      margin-top: 8.625rem ;
      width: 100%;
      margin-top: 4.688rem ;
      img{
        width:100%; 
        height: auto;    
      }
    }
    .p-footer-menu-container{
      border-bottom: 1px solid white;
      ul{
         list-style: none;
         font-size:12px;
         display: flex;
         flex-direction: column;
         gap: 20px;
         margin:0;
         padding:20px 0;
         li{
            a{
              color: white;
            }
         }

      }
    }
    .p-bottom-container{
      margin-top: 1.25rem;
      display: flex;
      flex-direction: column;
      gap:1.25rem;
        .p-legal-links{
          ul{
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: space-between;
            font-size: 0.62rem;
            li{
              a{
                color: white;                
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 1.5px;
              }
            }
          }  
        }
        .copyright{
          font-size: 0.62rem;
          span{
            font-weight: 700;
          }
        }
        .p-social-links{
          display: flex;
          gap:1.5rem;
          justify-content: center;
          a{
            color: white;
          }
        }
    }
  }
  @media(min-width:768px){
    .p-footer-container{
     
      padding: 7.5rem 2.43rem 1.25rem ;
      .p-top-cont{
        h4{
          font-size: 3.5rem;
          width: 434px;
        }
        p{
          font-size: 1rem;
          max-width: 35.12rem;
        }
        .p-email-container{
          min-width: 31rem;
          input{
            font-size:0.75rem;
          }
        }
      
      }
      .logo-container{
        margin-top: 8.625rem ;
      }
      .p-footer-menu-container{
        ul{
          flex-direction: row;
          justify-content: center;
          gap: 50px;
          padding:43px 22px;
        }
      }
      .p-bottom-container{
        margin-top: 1.37rem;
        flex-direction: row;
        justify-content: space-between;
          .p-legal-links{
            
            ul{
              list-style: none;
              margin: 0;
              padding: 0;
              display: flex;
              justify-content: space-between;
              font-size: 0.75rem;
              gap:40px;
            }  
          }
          .p-social-links{
            min-width: 170px;
            justify-content: end;
          }
        
      }
    }
  }

}

</style>


