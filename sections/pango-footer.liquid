</script>


{% schema %}
 {
 "name": "pango footer",
  "settings": [
  {
    "type": "link_list",
    "id": "legal_menu",
    "label": "Legal menu"
  },
  {
    "type": "url",
    "id": "instagram",
    "label": "Instagram"
  },
  {
    "type": "url",
    "id": "facebook",
    "label": "Facebook"
  },
  {
    "type": "url",
    "id": "youtube",
    "label": "YouTube"
  },
  {
    "type": "url",
    "id": "twitter",
    "label": "Twitter"
  },
  {
    "type": "url",
    "id": "tiktok",
    "label": "TikTok"
  }
  ],
  "blocks": [
    {
      "name": "newsletter text",
      "type": "newsletter_text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "title",
          "default": "YOU ARE INVITED to discover our world"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "description",
          "default": "<p> Receive intimate access to our perfumers’ craft and the inspirations that shape each fragrance.</p>"
        }
      ]
    },
    {
      "name": "logo",
      "type": "logo",
      "settings": [
        {
          "type": "image_picker",
          "label": "Image Picker 0",
          "id": "image_picker_0"
        }
      ]
    },
    {
      "name": "Footer menu",
      "type": "footer_menu",
      "settings": [
        {
          "type": "link_list",
          "id": "footer_menu",
          "label": "Footer menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "pango footer",
      "category": "All Pango"
    }
  ]
} 
{% endschema %}

