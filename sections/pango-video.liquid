<!-- pango-video.liquid -->
<section class="p-{{ section.id }}">
    <div class="video-container">
        {%- assign video = section.settings.video -%}
        {{ video | image_url: width: video.width | image_tag: class: 'add_your_class_here', loading: 'lazy' }}
        <div class="controls-container">
            <div class="progress-bar">

            </div>
            <div class="controls-container">

            </div>

        </div>
    </div>
</section>

<style>
.p-{{ section.id }}{
    .video-container{
        max-height:964px;
    }
}
</style>

{% schema %}
  {
  "name": "Pango video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "video"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Show progress bar",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Pango video"
    }
  ]
}  
{% endschema %}